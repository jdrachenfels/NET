@inject Web.Services.WebTranslationService T
@inject Web.Services.WebMenuService MenuService

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Web</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <header class="app-header">
            <div class="app-brand">
                <div class="app-logo">SGG</div>
                <div class="app-title">Web - @ViewData["Title"]</div>
            </div>

            <div class="app-user">
                @if (User?.Identity?.IsAuthenticated == true)
                {
                    <span>Hello @User.Identity.Name</span>
                    <span class="app-user-sep">-</span>
                    <a href="/logout">@T.T("menu.logout")</a>
                }
            </div>
        </header>

        <div class="app-main">
            <aside class="app-sidebar">
                @await Html.PartialAsync("_SidebarMenu", MenuService.GetMenu())
            </aside>

            <main class="app-content">
                @RenderBody()
            </main>
        </div>
    </div>
</body>
</html>